rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuth() {
      return request.auth != null;
    }

    // All data lives under /artifacts/{appId}/public/data/...
    // Any authenticated user can read and write — per-user permissions
    // will be configured once user roles are defined.
    match /artifacts/{artifactId}/public/data/{document=**} {
      allow read, write: if isAuth();
    }

    // Default deny everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
